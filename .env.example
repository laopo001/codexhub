CODEX_PROXY_HOST=127.0.0.1
CODEX_PROXY_PORT=8788
# Production can use the same .env by changing CODEX_PROXY_PORT to 18788
# and enabling static serving after `pnpm build`.
# CODEX_PROXY_ENV=production
# CODEX_PROXY_SERVE_STATIC=true
# CODEX_PROXY_STATIC_DIR=dist

# Leave unset for ChatGPT accounts; gpt-5-codex is not supported there.
# CODEX_MODEL=
CODEX_SANDBOX_MODE=danger-full-access
CODEX_APPROVAL_POLICY=on-request
CODEX_WEB_SEARCH_MODE=live
CODEX_NETWORK_ACCESS=true

# Optional: override the CLI/API endpoint used by @openai/codex-sdk.
# CODEX_API_KEY=
# CODEX_BASE_URL=
# CODEX_PATH_OVERRIDE=

# Telegram bot starts with the API server by default.
TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_IDS=

# Optional only for running `pnpm bot` as a standalone diagnostic process.
# CODEX_PROXY_SERVER_URL=http://127.0.0.1:8788
