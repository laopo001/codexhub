# Codex Hub server
CODEX_HUB_HOST=0.0.0.0
CODEX_HUB_PORT=8788
# CODEX_HUB_ENV=production
# CODEX_HUB_BUILD_ID=
# CODEX_HUB_STATIC_DIR=dist
# Optional: override the directory containing config.yaml. Defaults to ~/.config/codexhub.
# CODEX_HUB_DATA_DIR=
# Optional: require this token for CodexHub API and WebSocket access.
# CODEX_HUB_AUTH_TOKEN=
# Optional: also register this server as a registered machine with a parent CodexHub server.
# CODEX_HUB_REGISTER_TO may be a base URL or a Register URL with ?codexhub_token=.
# Self-registration is rejected; multiple local servers on different ports are allowed for testing.
# CODEX_HUB_REGISTER_TO=
# CODEX_HUB_REGISTER_AUTH_TOKEN=
# CODEX_HUB_REGISTER_MACHINE_ID=
# CODEX_HUB_REGISTER_NAME=
# CODEX_HUB_PLUGIN_DIR=
# CODEX_HUB_PLUGIN_DIRS=
# CODEX_HUB_SSH_CONFIG=
# CODEX_HUB_SSH_AUTOCONNECT=1
# CODEX_HUB_SSH_REMOTE_CLIENT_PATH=
# CODEX_HUB_LOCAL_MACHINE=1
# CODEX_HUB_LOCAL_MACHINE_ID=
# CODEX_HUB_LOCAL_MACHINE_NAME=local

# Codex CLI / app-server launch
# CODEX_HUB_CODEX_CLI=
# Optional: explicitly override values passed to `codex app-server -c ...`.
# When unset, CodexHub leaves the Codex CLI configuration unchanged.
# CODEX_HUB_APP_SERVER_APPROVAL_POLICY=on-request
# CODEX_HUB_APP_SERVER_APPROVALS_REVIEWER=auto_review
# CODEX_HUB_APP_SERVER_SANDBOX=danger-full-access
# CODEX_HUB_APP_SERVER_READY_TIMEOUT_MS=60000
# CODEX_HUB_CATALOG_CACHE_TTL_MS=21600000

# Electron wrapper
# CODEX_HUB_ELECTRON_DEVTOOLS=0

# Telegram
# Leave TELEGRAM_BOT_TOKEN unset to run the API server without Telegram.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_IDS=
# CODEX_HUB_PLUGIN_TELEGRAM=1

# Diagnostics and local tuning
# Optional only for running `pnpm bot` as a standalone diagnostic process.
# CODEX_HUB_SERVER_URL=http://127.0.0.1:8788
# CODEX_HUB_SESSION_OFFLINE_TIMEOUT_MS=45000
# CODEX_HUB_SESSION_OFFLINE_RETENTION_MS=1800000
# CODEX_HUB_SESSION_SWEEP_INTERVAL_MS=5000
# CODEX_HUB_THREAD_RECORD_SUBSCRIPTION_IDLE_MS=120000
# CODEX_HUB_TASK_SCAN_INTERVAL_MS=30000
# CODEX_HUB_TURN_TIMEOUT_MS=0
# Optional: run a local command when a non-historical task_complete record is received.
# The command receives a JSON payload on stdin.
# CODEX_HUB_NOTIFICATION_COMMAND=
# CODEX_HUB_NOTIFICATION_TIMEOUT_MS=5000
# CODEX_CONTEXT_WINDOW_TOKENS=
