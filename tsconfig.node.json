{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist-node",
    "rootDir": "src",
    "sourceMap": false,
    "declaration": false
  },
  "include": [
    "src/cli/**/*.ts",
    "src/core/**/*.ts",
    "src/electron/**/*.ts",
    "src/server/**/*.ts",
    "src/shared/**/*.ts",
    "src/telegram/**/*.ts"
  ]
}
