    "react": "^19.2.1",
    "react-dom": "^19.2.6",
    "react-virtuoso": "^4.18.7",
    "telegraf": "^4.16.3",
    "tsx": "^4.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
