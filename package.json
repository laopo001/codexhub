{
  "name": "@dadigua/codexhub",
  "version": "0.4.13",
  "description": "Local-first Codex control plane for local, SSH, and registered machines.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laopo001/codexhub.git"
  },
  "bugs": {
    "url": "https://github.com/laopo001/codexhub/issues"
  },
  "homepage": "https://github.com/laopo001/codexhub#readme",
  "files": [
    "bin",
    "scripts",
    "plugins",
    "targets",
    "src",
    "dist",
    "dist-node",
    "index.html",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    ".env.example",
    "ecosystem.config.cjs",
    "Dockerfile",
    ".dockerignore"
  ],
  "bin": {
    "codexhub": "bin/codexhub",
    "cxh": "bin/cxh"
  },
  "scripts": {
    "dev:api": "tsx src/cli/codexhub.ts server",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "bot": "tsx plugins/telegram/bot.ts",
    "codexhub": "tsx src/cli/codexhub.ts",
    "cxh": "tsx src/cli/codexhub.ts",
    "start": "node bin/codexhub server --host 0.0.0.0",
    "electron:start": "pnpm build && electron --no-sandbox dist-node/electron/main.js",
    "smoke:machine-session": "tsx scripts/smoke-machine-session.ts",
    "smoke:auth": "tsx scripts/smoke-auth.ts",
    "smoke:registered-machine": "tsx scripts/smoke-registered-machine.ts",
    "smoke:ssh-loopback": "tsx scripts/smoke-ssh-loopback.ts",
    "smoke:task-lock": "tsx scripts/smoke-task-lock.ts",
    "smoke:notification-hooks": "tsx scripts/smoke-notification-hooks.ts",
    "smoke:electron": "pnpm build && tsx scripts/smoke-electron.ts",
    "probe:app-server-transcript": "tsx scripts/probe-app-server-transcript.ts",
    "clean": "node -e \"const fs=require('node:fs'); for (const path of ['dist','dist-node']) fs.rmSync(path,{recursive:true,force:true});\"",
    "check": "tsc --noEmit",
    "build:electron": "tsx scripts/build-electron.ts",
    "build:remote-client": "tsx scripts/build-remote-client.ts",
    "build": "pnpm run clean && tsc --noEmit && tsc -p tsconfig.node.json && pnpm run build:electron && pnpm run build:remote-client && vite build",
    "build:vscode": "pnpm build && tsx scripts/build-vscode.ts",
    "package:vscode": "pnpm run build:vscode && cd dist-vscode && pnpm exec vsce package --no-dependencies --out codexhub.vsix",
    "install:vscode": "pnpm run package:vscode && tsx scripts/install-vscode-extension.ts",
    "prepack": "pnpm build",
    "publish:prod": "bash scripts/publish-prod.sh"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "antd": "^6.4.3",
    "commander": "^14.0.2",
    "fastify": "^5.6.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4.0.1",
    "telegraf": "^4.16.3",
    "tsx": "^4.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/vscode": "^1.120.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vscode/vsce": "^3.9.2",
    "electron": "^42.3.3",
    "esbuild": "0.28.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "packageManager": "pnpm@10.33.0"
}
