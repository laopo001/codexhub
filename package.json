{
  "name": "@dadigua/codexhub",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "bin",
    "src",
    "dist",
    "index.html",
    "README.md",
    "AGENTS.md"
  ],
  "bin": {
    "codexhub": "bin/codexhub",
    "cxh": "bin/cxh"
  },
  "scripts": {
    "dev:api": "tsx src/cli/codexhub.ts server",
    "bot": "tsx src/telegram/index.ts",
