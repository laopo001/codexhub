{
  "name": "codex-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "codexp": "./src/cli/codexp.ts"
  },
  "scripts": {
    "dev:api": "tsx src/cli/codexp.ts server",
    "bot": "tsx src/telegram/index.ts",
    "codexp": "tsx src/cli/codexp.ts",
    "cache:refresh": "tsx src/cli/refreshCache.ts",
    "check": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "publish:prod": "bash scripts/publish-prod.sh"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@openai/codex-sdk": "^0.133.0",
    "antd": "^6.4.3",
    "commander": "^14.0.2",
    "fastify": "^5.6.2",
    "node-pty": "^1.1.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.6",
    "react-virtuoso": "^4.18.7",
    "telegraf": "^4.16.3",
    "yaml": "^2.9.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "packageManager": "pnpm@10.33.0"
}
