{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "noEmit": true,
    "types": ["node"],
    "rootDir": "../.."
  },
  "include": [
    "src/**/*.ts",
    "../../src/server/**/*.ts",
    "../../src/core/**/*.ts",
    "../../src/shared/**/*.ts"
  ]
}
